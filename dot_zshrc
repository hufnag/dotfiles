# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time Oh My Zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="powerlevel10k/powerlevel10k"

# Uncomment the following line to enable command auto-correction.
#ENABLE_CORRECTION="true"

COMPLETION_WAITING_DOTS="true"
HISTSIZE=10000
SAVEHIST=10000
ZVM_SYSTEM_CLIPBOARD_ENABLED=true
ZVM_VI_INSERT_ESCAPE_BINDKEY=kj
setopt histignorealldups                                        # If a new command is a duplicate, remove the older one
setopt nobeep                                                   # No beep
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

PYTHON_AUTO_VRUN=true

# Uncomment the following line if you want to disable marking untracked files
# under VCS as dirty. This makes repository status check for large repositories
# much, much faster.
# DISABLE_UNTRACKED_FILES_DIRTY="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Uncomment the following line if you want to change the command execution time
# stamp shown in the history command output.
# You can set one of the optional three formats:
# "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd"
# or set a custom format using the strftime function format specifications,
# see 'man strftime' for details.
# HIST_STAMPS="mm/dd/yyyy"

plugins=(
    copyfile # Adds `copyfile` cmd to copy file content into clipboard
    copypath # Adds `copypath` cmd to copy path into clipboard
    docker # Adds auto completion
    dirhistory # Alt + arrow keys to navigate dirs
    docker-compose # Adds auto completion
    dotenv # Automatically source '.env' when cd into the dir. For exporting env vars
    fzf
    git
    python
    systemd
    wd
    zoxide
    zsh-autosuggestions
    zsh-history-substring-search
    zsh-syntax-highlighting
    zsh-vi-mode
)

eval "$(atuin init zsh --disable-up-arrow)"

source $ZSH/oh-my-zsh.sh


source $HOME/.config/zsh/rsync_wrapper.zsh

# Fix conflicts with vi-mode plugin
function zvm_after_init() {
  source <(fzf --zsh)
  bindkey -M viins '^P' up-line-or-beginning-search
  bindkey -M viins '^N' down-line-or-beginning-search
  bindkey -M viins '^R' _atuin_search_widget
  bindkey -M vicmd '^R' _atuin_search_widget
  bindkey -M viins '^U' backward-kill-line
}

export EDITOR='nvim'
export BAT_THEME="gruvbox-dark"
export MANPAGER="moor"

# export LANG=en_US.UTF-8
alias zshconfig="nvim ~/.zshrc"
alias ohmyzsh="nvim ~/.oh-my-zsh"

alias lg=lazygit
# Eza aliases
alias ls='eza --icons=auto --git'
alias ll='eza -lah --git --icons=auto'
alias lsa='eza -a --icons=auto'
alias lst='eza --tree --level=2 --icons=auto'
alias lsta='eza -a --tree --level=2 --icons=auto'
alias lstt='eza --tree --icons=auto'
alias lstta='eza -a --tree --icons=auto'
alias rmd='rm -rf'
alias cpd='cp -r'

alias zed='zeditor'

alias lvim='NVIM_APPNAME=lazyvim nvim'

alias cz='chezmoi'
alias czu='chezmoi update'
alias czd='chezmoi diff'
alias czs='chezmoi status'



# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
